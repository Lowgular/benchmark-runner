{
  "$schema": "https://raw.githubusercontent.com/oasis-tcs/sarif-spec/master/Schemata/sarif-schema-2.1.0.json",
  "version": "2.1.0",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "lowgular-static-analysis",
          "version": "0.0.0",
          "rules": [
            {
              "id": "angular.dependency-injection.constructor-params",
              "properties": {
                "skill": "skills/constructor-params_inject-function.md"
              }
            },
            {
              "id": "angular.change-detection.default",
              "properties": {
                "skill": "skills/change-detection_default_none.md"
              }
            }
          ]
        }
      },
      "results": [
        {
          "ruleId": "angular.dependency-injection.constructor-params",
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "src/app/product.service.ts"
                },
                "region": {
                  "startLine": 11,
                  "startColumn": 15,
                  "endLine": 11,
                  "endColumn": 39
                }
              }
            }
          ]
        },
        {
          "ruleId": "angular.dependency-injection.constructor-params",
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "src/app/app.ts"
                },
                "region": {
                  "startLine": 16,
                  "startColumn": 15,
                  "endLine": 16,
                  "endColumn": 53
                }
              }
            }
          ]
        },
        {
          "ruleId": "angular.change-detection.default",
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "src/app/app.ts"
                },
                "region": {
                  "startLine": 6,
                  "startColumn": 1,
                  "endLine": 12,
                  "endColumn": 3
                }
              }
            }
          ]
        }
      ]
    }
  ]
}